# Student Data Wall runtime environment template
# Copy this file to .env.docker before first run:
# cp .env.docker.example .env.docker

# Runtime release identifier for support context.
RUNTIME_VERSION=v0.2.1

# Pinned app image reference. Use a release tag or immutable digest.
# Recommended format:
# APP_IMAGE=ghcr.io/pvtl/student-data-wall-docker@sha256:<digest>
APP_IMAGE=ghcr.io/pvtl/student-data-wall-docker@sha256:5e7c2c4fddfb17265d7d5a30070cee765d4dcc298f1ada38e2f4786554e325bc

# Host port mapped to container port 80.
APP_PORT=80

# Laravel application settings
APP_ENV=production
APP_DEBUG=false
APP_NAME="Student Data Wall"
APP_KEY=

# Database configuration (SQLite)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/storage/app/database/database.sqlite
